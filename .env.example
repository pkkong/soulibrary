# Soulib / library_crawler development environment
#
# Copy this file to .env only if you want a local reference.
# The app does not require .env for basic live-search development.

# Flask search server
LIBRARY_SEARCH_PORT=5001
# PORT is used by some cloud platforms. LIBRARY_SEARCH_PORT wins if both are set.
PORT=5001

# Live search tuning
LIVE_SEARCH_TTL_SEC=600
LIVE_SEARCH_CACHE_SIZE=256
LIVE_SEARCH_LIBRARY_TIMEOUT=4.5
LIVE_SEARCH_TOTAL_TIMEOUT=5.8
LIVE_SEARCH_MAX_WORKERS=40
LIVE_SEARCH_PER_LIBRARY_LIMIT=10
LIVE_DETAIL_CACHE_SIZE=1024
KYOBO_STATUS_TTL=120

# Optional public URLs
PUBLIC_BASE_URL=
SITEMAP_BASE_URL=

# Optional API CORS origins for external JSON clients.
# Defaults already include Toss Apps and local Vite development:
# https://soulib.apps.tossmini.com, https://soulib.private-apps.tossmini.com,
# http://localhost:5173, http://127.0.0.1:5173
API_CORS_ALLOWED_ORIGINS=

# Optional Google Search Console reporting.
# Service account: grant the service account access to the Search Console property first.
GSC_SITE_URL=https://www.soulib.kr/
GSC_SERVICE_ACCOUNT_FILE=.secrets/search-console-service-account.json
# Alternative for CI/secret managers: raw service account JSON.
GSC_SERVICE_ACCOUNT_JSON=
# OAuth desktop client: run scripts/search_console_report.py --authorize once.
GSC_OAUTH_CLIENT_FILE=.secrets/search-console-oauth-client.json
GSC_OAUTH_TOKEN_FILE=.secrets/search-console-oauth-token.json
GSC_REPORT_ROW_LIMIT=10

# Optional SQLite DB fallback for legacy pages and admin scripts
LIBRARY_DB_PATH=
LIBRARY_SPLIT_DB_PATH=

# Optional PostgreSQL settings for legacy DB/admin workflows
DATABASE_URL=
DB_HOST=
DB_PORT=5432
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_SSLMODE=require

# Shared shelf storage.
# json: local only, stores shared links in SHARED_SHELVES_FILE.
# postgres: force production PostgreSQL, requires DATABASE_URL or DB_HOST.
# auto: use PostgreSQL when DATABASE_URL/DB_HOST is set, otherwise local JSON.
SHARED_SHELVES_STORAGE=auto
SHARED_SHELVES_FILE=

# GitHub Issues are the single source of truth for /reports submissions.
# Production must set a token with Issues read/write access.
GITHUB_ISSUE_TOKEN=
GITHUB_ISSUE_REPO=pkkong/library_crawler
GITHUB_ISSUE_LABELS=
GITHUB_ISSUE_TIMEOUT=8

# Optional crawler/API keys.
# Keep real secrets out of GitHub. Put production values in GitHub/Vercel secrets.
ODCLOUD_API_KEY=
SEOUL_API_KEY=
SEOULIB_TG_BOT_TOKEN=
SEOULIB_TG_CHAT_ID=
