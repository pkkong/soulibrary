{
  "name": "library-crawler",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.11-bullseye",
  "forwardPorts": [5001],
  "portsAttributes": {
    "5001": {
      "label": "Soulib Search",
      "onAutoForward": "openBrowser"
    }
  },
  "postCreateCommand": "python -m pip install --upgrade pip && pip install -r requirements.txt && python scripts/smoke_test.py",
  "customizations": {
    "vscode": {
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python"
      },
      "extensions": [
        "ms-python.python"
      ]
    }
  }
}
